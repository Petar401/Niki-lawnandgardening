# Copy this file to .env.local for development, or set these in your host's
# environment variables panel for production. Never commit a filled-in .env.

# Where the contact form posts enquiries. Compatible with any service that
# accepts a JSON body (Formspree, Resend with an edge function, Netlify
# Forms via an action= override, or your own endpoint). When empty, the
# form falls back to a mailto: link using VITE_PUBLIC_EMAIL or site.contact.email.
VITE_FORM_ENDPOINT=

# Canonical site URL once a domain is chosen, e.g. https://nikilawnandgardening.co.uk
# Appears in the LocalBusiness JSON-LD "url" field. When unset, falls back
# to window.location.origin at runtime.
VITE_SITE_URL=

# Optional convenience duplicates for SEO / structured data. The site
# already reads these from src/content/site.ts; setting them here lets you
# override per-deployment without editing source.
VITE_PUBLIC_PHONE=
VITE_PUBLIC_EMAIL=
